# Generio Platform — environment template
# Copy to .env (root) or set in your host. Do not commit real secrets.

# PostgreSQL (matches docker-compose.yml)
POSTGRES_DB=generio
POSTGRES_USER=generio
POSTGRES_PASSWORD=generio_dev_password
POSTGRES_PORT=5433

# API
ConnectionStrings__Default=Host=localhost;Port=5433;Database=generio;Username=generio;Password=generio_dev_password
Jwt__Issuer=generio-api
Jwt__Audience=generio-web
Jwt__SigningKey=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_32PLUS
Jwt__AccessTokenMinutes=30
Jwt__RefreshTokenDays=14
Seed__AdminEmail=admin@generiogroup.com
Seed__AdminPassword=ChangeMe!Generio1

# Storage provider: Local | AzureBlob | S3 | CloudflareR2
Storage__Provider=Local
Storage__ConnectionString=
Storage__ContainerOrBucket=generio-media
Storage__PublicBaseUrl=
Storage__Region=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:5080
NEXT_PUBLIC_SITE_URL=http://localhost:3000
Cors__AllowedOrigins__0=http://localhost:3000

# Railway production (see generio-docs/RAILWAY.md)
# DATABASE_URL=postgresql://...   # from Railway Postgres — preferred over ConnectionStrings__Default
# ASPNETCORE_ENVIRONMENT=Production
# Cors__AllowedOrigins__0=https://your-web.up.railway.app
# Storage__PublicBaseUrl=https://your-api.up.railway.app
# Site__PublicBaseUrl=https://your-web.up.railway.app
# NEXT_PUBLIC_API_BASE_URL / NEXT_PUBLIC_SITE_URL must match public Railway URLs (build-time for Next.js)

# Hosting: Railway (API + web + Postgres) — media volume at /app/App_Data/media recommended
# Alternatives: Frontend Vercel | API Azure App Service | DB Neon/Supabase | Media R2/S3/Azure Blob
